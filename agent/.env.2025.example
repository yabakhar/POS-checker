# === Configuration Agent Local POS — Clyo 2025 === (F-08)
# Modèle pour tester l'agent en local contre l'instance MySQL du Clyo 2025,
# une fois l'utilisateur agentPos créé (voir agent/reset-agentpos-user-2025.bat).
#
# Pour l'utiliser : copier ce fichier en ".env" (remplace la config 2015
# active) une fois le Clyo 2025 démarré sur ce poste.
# Ces mêmes valeurs (DB_USER/DB_PASSWORD) sont celles injectées automatiquement
# dans le .env généré pour les clients par backend/src/routes/client.js
# (POS_VERSION_DB_CREDENTIALS['2025']) — garder les deux synchronisés.

SHOP_TOKEN=042de715e4a043e0aff039da7e99269be5c4e93ca0a846cea7ff95851307f9f4

# --- Base MySQL locale de la caisse (Clyo 2025) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=agentPos
DB_PASSWORD=
DB_NAME=dbclyo

CLOUD_API_URL=http://localhost:3001

DRY_RUN=false
DRY_RUN_FILE=./data/test-output.json

WATCHED_TABLES=*

SYNC_TABLES_SECONDS=3600

RETRY_INTERVAL_SECONDS=60

LOG_LEVEL=info
LOG_DIR=./logs
