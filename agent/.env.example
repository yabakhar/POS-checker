# === Configuration Agent Local POS === (F-08)
# Copier ce fichier en ".env" et remplir les vraies valeurs.
# Ce fichier ne doit JAMAIS être commité dans Git (voir .gitignore).

# --- Identité du magasin ---
# Obligatoire dès que DRY_RUN=false (config livrée au client) ; peut rester
# vide en DRY_RUN=true (config de test, fallback "test-token" automatique).
SHOP_TOKEN=

# --- Base de données POS locale (lecture seule) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pos_agent
DB_PASSWORD=
DB_NAME=pos_db

# --- API Cloud ---
CLOUD_API_URL=https://api.votre-domaine.com

# --- Mode test (optionnel) ---
# Si true : les données ne sont PAS envoyées au cloud, elles sont juste
# sauvegardées dans DRY_RUN_FILE pour que tu puisses voir ce qui serait envoyé.
# Utile pour tester avant d'avoir un compte/API cloud prêt.
DRY_RUN=false
DRY_RUN_FILE=./data/test-output.json

# --- Tables génériques à surveiller (proposé automatiquement par npm run setup) ---
# Vide = aucune, "*" = toutes les tables, ou liste "table1,table2".
# Seules les lignes nouvelles/modifiées depuis le dernier cycle sont envoyées.
WATCHED_TABLES=

# --- Fréquence de synchronisation des tables surveillées (en secondes) ---
SYNC_TABLES_SECONDS=3600

# --- Reconnexion (F-06) ---
RETRY_INTERVAL_SECONDS=60

# --- Logs (F-07) ---
LOG_LEVEL=info
LOG_DIR=./logs
